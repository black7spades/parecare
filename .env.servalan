# PareCare — Servalan test environment
# Copy this to .env before starting:
#   cp .env.servalan .env

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=parecare
DB_USER=parecare
DB_PASSWORD=changeme_strong_password

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_string
APP_URL=http://servalan:3000

# ── Mode ──────────────────────────────────────────────────────────────────────
# true  = no Stripe, no usage limits, full access (good for local testing)
# false = SaaS mode with subscription gating
SELF_HOSTED=true

# ── AI assistant ──────────────────────────────────────────────────────────────
# Set your Anthropic API key to enable Ask PareCare on the self-hosted stack
ANTHROPIC_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
# local = store uploads in the Docker volume (fine for testing)
# s3    = requires S3_* vars below (SaaS only)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/app/uploads

S3_BUCKET=
S3_REGION=ap-southeast-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave blank to disable email (invites will still work, just no emails sent)
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@parecare.local

# ── Stripe (SaaS only — leave blank for SELF_HOSTED=true) ────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FAMILY=
STRIPE_PRICE_PROFESSIONAL=

# ── AI token limits ───────────────────────────────────────────────────────────
# Ignored when SELF_HOSTED=true
AI_TOKENS_FREE=0
AI_TOKENS_FAMILY=100000
AI_TOKENS_PROFESSIONAL=-1
