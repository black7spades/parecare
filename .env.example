# Database
DB_NAME=parecare
DB_USER=parecare
DB_PASSWORD=changeme

# App
NODE_ENV=production
PORT=80
JWT_SECRET=generate-a-long-random-string-min-32-chars
API_URL=http://localhost:3001

# Self-host mode (set to false for SaaS deployment)
SELF_HOSTED=true

# AI (optional for self-host, required for SaaS)
ANTHROPIC_API_KEY=

# Storage (local = uploads folder, s3 = AWS S3 compatible)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/app/uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@parecare.app

# Subscriptions (SaaS only — leave empty for self-hosted)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FAMILY=
STRIPE_PRICE_PROFESSIONAL=

# App URL (used for Stripe redirect URLs)
APP_URL=http://localhost

# Plan limits (tokens per billing cycle, -1 = unlimited)
AI_TOKENS_FREE=0
AI_TOKENS_FAMILY=100000
AI_TOKENS_PROFESSIONAL=-1
