{
  "name": "@parecare/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node scripts/migrate.js latest",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "migrate:status": "node scripts/migrate.js status",
    "seed": "node -e \"console.log('Nothing to seed — checklist templates are built into the app and applied when care profiles are created.')\"",
    "seed:dev": "node scripts/seed-dev.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@types/web-push": "^3.6.4",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "rrule": "^2.7.0",
    "stripe": "^14.0.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/uuid": "^9.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
